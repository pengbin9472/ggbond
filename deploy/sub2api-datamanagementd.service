[Unit]
Description=GGbond Data Management Daemon
After=network.target
Wants=network.target

[Service]
Type=simple
User=ggbond
Group=ggbond
WorkingDirectory=/opt/ggbond
ExecStart=/opt/ggbond/datamanagementd \
  -socket-path /tmp/ggbond-datamanagement.sock \
  -sqlite-path /var/lib/ggbond/datamanagement/datamanagementd.db \
  -version 1.0.0
Restart=always
RestartSec=5s
LimitNOFILE=100000
NoNewPrivileges=true
PrivateTmp=false

[Install]
WantedBy=multi-user.target
